# Kanoniczny URL aplikacji (wysyłka e-maili z fakturami; na Vercel można polegać na VERCEL_URL)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Fakturownia API — faktury zaliczkowe / zamówienia (estimate)
FAKTUROWNIA_API_TOKEN=
FAKTUROWNIA_SUBDOMAIN=
# Pełna nazwa sprzedawcy (jak w ustawieniach firmy w Fakturowni) — często wymagane przez API (422: seller_name)
FAKTUROWNIA_SELLER_NAME=
# Opcjonalnie: NIP i adres sprzedawcy, jeśli API tego wymaga
# FAKTUROWNIA_SELLER_TAX_NO=
# FAKTUROWNIA_SELLER_STREET=
# FAKTUROWNIA_SELLER_CITY=
# FAKTUROWNIA_SELLER_POST_CODE=
# FAKTUROWNIA_SELLER_COUNTRY=PL
# Opcjonalnie: "true" jeśli konto w Fakturowni wymusza procedurę marży na fakturach (legacy: tylko margin_procedure)
# FAKTUROWNIA_MARGIN_PROCEDURE=true
# Pełny tryb VAT marża pod KSeF (biuro podróży, art. 119): pozycje tax="disabled",
# procedure_vat_margin="procedura marży dla biur podróży" + procedure_designations=["MR_T"]
# + margin_procedure=true. Domyślnie OFF. Włącz po potwierdzeniu z księgowym.
# VAT_MARGIN_MODE=true
# Stawka VAT od marży dla pozycji marżowych (aktywne tylko przy VAT_MARGIN_MODE=true).
# Na testy 23; ostateczną wartość ustalić z księgową. Domyślnie "23" gdy nie ustawiono.
# VAT_MARGIN_TAX=23
# Automatyczna wysyłka faktur do KSeF po wystawieniu (wymagana, gdy konto blokuje
# pobieranie PDF przed nadaniem numeru KSeF). UWAGA: produkcyjny KSeF = realne
# zgłoszenia fiskalne. Działa tylko w produkcji (NODE_ENV=production). Domyślnie OFF.
# FAKTUROWNIA_KSEF_AUTOSEND=true

# Resend — e-maile (w tym PDF faktur)
RESEND_API_KEY=
# RESEND_FROM=Name <localpart@domena.pl>
# RESEND_FROM_NAME=Magia Podróży
